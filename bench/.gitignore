# Dumped benchmark payloads (regenerated by `bench-report --dump-payloads`).
payloads/

# Real-corpus cache (materialized by fetch_corpora.sh). Canterbury (~2.8 MB) is
# committed so CI needs no network; larger corpora (e.g. Silesia) are fetched on
# demand and stay untracked.
corpora/*
!corpora/canterbury/

# Built external comparator binaries + toolchain caches (regenerated by
# comparators/build_all.sh — sources are tracked, artifacts are not).
comparators/go/bench-go
comparators/zig/bench-zig
comparators/zig/*.o
comparators/zig/.zig-cache/
comparators/zig/zig-cache/
comparators/ocaml/bench-ocaml
comparators/ocaml/_build/
comparators/js/node_modules/
comparators/js/package-lock.json
