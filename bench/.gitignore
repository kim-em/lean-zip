# Dumped benchmark payloads (regenerated by `bench-report --dump-payloads`).
payloads/

# Dumped fixed-encoder (libdeflate) raw-DEFLATE streams for the decode-density
# experiment (regenerated by `bench-report --decode-density`). The resulting
# decode_density.json under results/ is tracked; these input streams are not.
payloads-deflate/

# Real-corpus cache (materialized by fetch_corpora.sh). Canterbury (~2.8 MB) is
# committed so CI needs no network; larger corpora (e.g. Silesia) are fetched on
# demand and stay untracked.
corpora/*
!corpora/canterbury/

# Hidden before/after snapshot graphs from the perf-comparison workflow. Only the
# dashboard graphs (graphs/*.svg, produced by plot.py and referenced by README.md)
# are tracked; the `.hid_*` baseline snapshots are a report artifact, not committed.
graphs/.hid_*

# Built external comparator binaries + toolchain caches (regenerated by
# comparators/build_all.sh — sources are tracked, artifacts are not).
comparators/go/bench-go
comparators/zig/bench-zig
comparators/zig/*.o
comparators/zig/.zig-cache/
comparators/zig/zig-cache/
comparators/ocaml/bench-ocaml
comparators/ocaml/_build/
comparators/js/node_modules/
comparators/js/package-lock.json

# Optional pareto-history outputs (bench/pareto_history.py --video / --html).
# Only the animated SVG (graphs/*_compress_pareto_history.svg, embedded by
# README.md) is tracked; the video renders and the interactive player are
# regenerable report artifacts.
graphs/*_compress_pareto_history.mp4
graphs/*_compress_pareto_history.gif
graphs/*_compress_pareto_history.html
