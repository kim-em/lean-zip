import Zip

/-! # BitWriter wide-store kernel microbenchmark (issue #2631, step 0)

Compares four bit-emission kernels over the same synthetic field trace
(LSB-first DEFLATE-style fields, mostly 7-9 bit "literals" with occasional
3-13 bit extra fields, generated by an in-loop LCG so the trace costs no
memory traffic):

- **A push/byte** — the production `BitWriter.writeBits` path: per-call
  `flushBytes` loop, one `ByteArray.push` per completed byte.
- **B push wide** — same grow-by-push writer, but the per-byte flush loop
  replaced by one `ByteArray.pushUInt64LE` call (unconditional 8-byte store
  into capacity slack + size bump, `c/bytearray_wide_ffi.c`).
- **C uset wide** — pre-sized output buffer + byte cursor;
  `ByteArray.usetUInt64LE` at the cursor every call (the issue's step-2/3
  shape, still flushing every call).
- **D deferred** — pre-sized buffer + 64-bit accumulator that only flushes
  (one `usetUInt64LE`) once ≥ 33 bits are pending, i.e. every ~4 fields
  (the libdeflate-style ceiling).

All four are checked byte-identical before timing. Run:
`lake exe wide-store-bench [fields] [reps]` (defaults 2000000, 7).
-/

open Zip.Native (BitWriter)
open Zip.Native.BitWriter (dropBytes)

/-- Deterministic LCG (Knuth MMIX constants). -/
@[inline] def lcg (x : UInt64) : UInt64 :=
  x * 6364136223846793005 + 1442695040888963407

/-- Derive a field `(n, val)` from LCG state: every 8th field is a 3-13 bit
    "extra bits" field, the rest are 7-9 bit "literal code" fields. -/
@[inline] def fieldOf (x : UInt64) : Nat × UInt32 :=
  let n := if x &&& 7 == 0 then ((3 : UInt64) + ((x >>> 8) % 11)).toNat
           else ((7 : UInt64) + ((x >>> 8) % 3)).toNat
  (n, (x >>> 24).toUInt32)

/-! ## Variant A: production BitWriter (push per byte) -/

def loopA : Nat → BitWriter → UInt64 → BitWriter
  | 0, bw, _ => bw
  | i + 1, bw, x =>
    let x := lcg x
    let (n, v) := fieldOf x
    loopA i (bw.writeBits n v) x

def runA (fields : Nat) (seed : UInt64) : ByteArray :=
  (loopA fields BitWriter.empty seed).flush

/-! ## Variant B: grow-by-push writer, wide-store flush -/

structure BWB where
  data : ByteArray
  bitBuf : UInt8
  bitCount : UInt8

@[inline] def writeBitsB (bw : BWB) (n : Nat) (val : UInt32) : BWB :=
  let masked : UInt64 := val.toUInt64 % (1 <<< n.toUInt64)
  let acc : UInt64 := bw.bitBuf.toUInt64 ||| (masked <<< bw.bitCount.toUInt64)
  let total := bw.bitCount.toNat + n
  let k := total / 8
  if h : k ≤ 8 then
    ⟨bw.data.pushUInt64LE acc k.toUSize
        (Nat.le_trans (Nat.mod_le _ _) h),
      (dropBytes acc k).toUInt8, (total % 8).toUInt8⟩
  else -- unreachable: total ≤ 7 + 25
    ⟨bw.data, 0, 0⟩

def loopB : Nat → BWB → UInt64 → BWB
  | 0, bw, _ => bw
  | i + 1, bw, x =>
    let x := lcg x
    let (n, v) := fieldOf x
    loopB i (writeBitsB bw n v) x

def runB (fields : Nat) (seed : UInt64) : ByteArray :=
  let bw := loopB fields ⟨.empty, 0, 0⟩ seed
  if bw.bitCount > 0 then bw.data.push bw.bitBuf else bw.data

/-! ## Variant C: pre-sized buffer + cursor, wide store every call -/

structure BWC where
  buf : ByteArray
  pos : USize
  bitBuf : UInt8
  bitCount : UInt8

@[inline] def writeBitsC (bw : BWC) (n : Nat) (val : UInt32) : BWC :=
  let masked : UInt64 := val.toUInt64 % (1 <<< n.toUInt64)
  let acc : UInt64 := bw.bitBuf.toUInt64 ||| (masked <<< bw.bitCount.toUInt64)
  let total := bw.bitCount.toNat + n
  let k := total / 8
  if h : bw.pos.toNat + 8 ≤ bw.buf.size then
    ⟨bw.buf.usetUInt64LE bw.pos acc h, bw.pos + k.toUSize,
      (dropBytes acc k).toUInt8, (total % 8).toUInt8⟩
  else -- unreachable: buffer is pre-sized
    ⟨bw.buf, bw.pos, 0, 0⟩

def loopC : Nat → BWC → UInt64 → BWC
  | 0, bw, _ => bw
  | i + 1, bw, x =>
    let x := lcg x
    let (n, v) := fieldOf x
    loopC i (writeBitsC bw n v) x

def runC (fields : Nat) (seed : UInt64) (zeros : ByteArray) : ByteArray :=
  let bw := loopC fields ⟨zeros, 0, 0, 0⟩ seed
  let out := bw.buf.extract 0 bw.pos.toNat
  if bw.bitCount > 0 then out.push bw.bitBuf else out

/-! ## Variant D: pre-sized buffer + 64-bit accumulator, deferred flush -/

structure BWD where
  buf : ByteArray
  pos : USize
  acc : UInt64
  bitCount : UInt64  -- ≤ 32 on entry to writeBitsD

@[inline] def writeBitsD (bw : BWD) (n : Nat) (val : UInt32) : BWD :=
  let masked : UInt64 := val.toUInt64 % (1 <<< n.toUInt64)
  let acc : UInt64 := bw.acc ||| (masked <<< bw.bitCount)
  let total : UInt64 := bw.bitCount + n.toUInt64
  if total ≥ 33 then
    if h : bw.pos.toNat + 8 ≤ bw.buf.size then
      let k : UInt64 := total >>> 3
      ⟨bw.buf.usetUInt64LE bw.pos acc h, bw.pos + k.toUSize,
        acc >>> (k <<< 3), total &&& 7⟩
    else -- unreachable: buffer is pre-sized
      ⟨bw.buf, bw.pos, 0, 0⟩
  else
    ⟨bw.buf, bw.pos, acc, total⟩

def loopD : Nat → BWD → UInt64 → BWD
  | 0, bw, _ => bw
  | i + 1, bw, x =>
    let x := lcg x
    let (n, v) := fieldOf x
    loopD i (writeBitsD bw n v) x

/-- Final flush for D: spill remaining whole bytes, then the partial byte. -/
partial def drainD (buf : ByteArray) (pos : USize) (acc : UInt64) (bits : UInt64) : ByteArray :=
  if bits ≥ 8 then
    drainD (buf.set! pos.toNat acc.toUInt8) (pos + 1) (acc >>> 8) (bits - 8)
  else
    let out := buf.extract 0 pos.toNat
    if bits > 0 then out.push acc.toUInt8 else out

def runD (fields : Nat) (seed : UInt64) (zeros : ByteArray) : ByteArray :=
  let bw := loopD fields ⟨zeros, 0, 0, 0⟩ seed
  drainD bw.buf bw.pos bw.acc bw.bitCount

/-! ## Harness -/

/-- Time `op` once, returning (ns, result size). The per-rep `seed` argument
    keeps the optimizer from CSE-ing the timed call against the verification
    run in `main`; `@[noinline]` keeps it from hoisting the call. -/
@[noinline] def timeOnce (seed : UInt64) (op : UInt64 → ByteArray) : IO (Nat × Nat) := do
  let t0 ← IO.monoNanosNow
  let out := op seed
  -- an IO action depending on `out` keeps the pure call inside the window
  if out.size == 0 then IO.eprintln "unreachable"
  let t1 ← IO.monoNanosNow
  return (t1 - t0, out.size)

def medianNs (xs : List Nat) : Nat :=
  let a := xs.toArray.qsort (· < ·)
  if a.size == 0 then 0 else a[a.size / 2]!

def bench (label : String) (fields reps : Nat) (seed : UInt64)
    (op : UInt64 → ByteArray) : IO Nat := do
  let mut ts : List Nat := []
  let mut sz := 0
  for i in [:reps] do
    let (ns, s) ← timeOnce (seed + i.toUInt64 + 1) op
    ts := ns :: ts
    sz := s
  let med := medianNs ts
  let nsPerField100 := med * 100 / fields
  let mbps := if med == 0 then 0 else sz * 1000 / med  -- MB/s of output
  IO.println s!"| {label} | {nsPerField100 / 100}.{nsPerField100 % 100} | {mbps} | {sz} |"
  return med

def main (args : List String) : IO Unit := do
  let fields := (args[0]?.bind (·.toNat?)).getD 2000000
  let reps := (args[1]?.bind (·.toNat?)).getD 7
  let seed : UInt64 := 0x243F6A8885A308D3
  -- pre-sized zero buffer for C/D: ≤ 2 bytes/field plus slack
  let zeros := ByteArray.mk (Array.replicate (fields * 2 + 64) 0)
  -- correctness: all variants byte-identical on a small trace and the big one
  let a := runA fields seed
  let b := runB fields seed
  let c := runC fields seed zeros
  let d := runD fields seed zeros
  unless a == b do throw (IO.userError "B mismatch vs A")
  unless a == c do throw (IO.userError "C mismatch vs A")
  unless a == d do throw (IO.userError "D mismatch vs A")
  IO.println s!"fields={fields} reps={reps} output={a.size} bytes (all variants byte-identical)"
  IO.println ""
  IO.println "| variant | ns/field | MB/s out | bytes |"
  IO.println "|---------|----------|----------|-------|"
  let tA ← bench "A push/byte  " fields reps seed (fun s => runA fields s)
  let tB ← bench "B push wide  " fields reps seed (fun s => runB fields s)
  let tC ← bench "C uset wide  " fields reps seed (fun s => runC fields s zeros)
  let tD ← bench "D deferred   " fields reps seed (fun s => runD fields s zeros)
  IO.println ""
  IO.println s!"speedup vs A: B ×{tA * 100 / max tB 1}%, C ×{tA * 100 / max tC 1}%, D ×{tA * 100 / max tD 1}%"
